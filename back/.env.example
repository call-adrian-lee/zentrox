PORT=3000
# Local MySQL — copy to `back/.env` and set real values (never commit `.env`).
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=zentrox
# Required for admin JWT; use 32+ random characters.
JWT_SECRET=change_me_use_a_long_random_secret_with_32_plus_chars
# Optional: if behind a reverse proxy (Nginx/Cloudflare), keep 1. Set 0 for direct local access only.
# TRUST_PROXY=1
# Optional API rate-limits (requests per window)
# RATE_LIMIT_MAX=400
# AUTH_RATE_LIMIT_MAX=8
# APPLICATION_RATE_LIMIT_MAX=20
# Comma-separated extra CORS origins (production SPA URL, staging, etc.)
# CORS_ORIGINS=https://staging.zentrox.us
# MySQL pool size (default 10)
# MYSQL_POOL_SIZE=10
# Optional bootstrap admin credentials (used by `npm run db:bootstrap`).
# If ADMIN_BOOTSTRAP_PASSWORD is omitted, a strong random password is generated and printed once.
# ADMIN_BOOTSTRAP_USERNAME=admin
# ADMIN_BOOTSTRAP_PASSWORD=
# Optional absolute path for admin-uploaded portfolio thumbnails (API default resolves to repo `front/img/portfolio`).
# PORTFOLIO_UPLOAD_DIR=
