{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "types": ["vitest/globals"],
    "baseUrl": "src",
    "paths": {
      "@core/*": ["app/core/*"],
      "@shared/*": ["app/shared/*"],
      "@user/*": ["app/user/*"],
      "@admin/*": ["app/admin/*"]
    }
  },
  "include": ["src/**/*.d.ts", "src/**/*.spec.ts"]
}
