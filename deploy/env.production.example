# Copy to /var/www/zentrox/back/.env on the VPS (never commit .env).
PORT=3000
NODE_ENV=production

# MySQL — use socket on Ubuntu (recommended) OR host + port:
# MYSQL_SOCKET=/var/run/mysqld/mysqld.sock
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=zentrox
MYSQL_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MYSQL_DATABASE=zentrox

# Required: 32+ random characters (openssl rand -base64 48)
JWT_SECRET=CHANGE_ME_USE_openssl_rand_base64_48

# Behind Nginx reverse proxy (rate limits + client IP)
TRUST_PROXY=1

# Optional: only if SPA is on another origin (same-origin prod usually omits this)
# CORS_ORIGINS=https://www.zentrox.us

# Bootstrap admin (run once: npm run db:bootstrap --prefix back)
# ADMIN_BOOTSTRAP_USERNAME=admin
# ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_ROTATE_AFTER_BOOTSTRAP

# Portfolio uploads (default: repo front/img/portfolio — must be writable by www-data)
# PORTFOLIO_UPLOAD_DIR=/var/www/zentrox/front/img/portfolio
